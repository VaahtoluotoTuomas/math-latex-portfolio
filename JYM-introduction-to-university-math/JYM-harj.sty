  \begin{enumerate}
  \renewcommand{\theenumi}{\arabic{enumi})}
  \renewcommand{\labelenumi}{\theenumi}
  \setlength{\itemsep}{0cm}
}
{\end{enumerate}}

\newenvironment{aakkosta*}{
