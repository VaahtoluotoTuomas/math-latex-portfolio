\newcommand{\valiteksti}[1]{\ifthenelse{\tversio = 1}{\noindent #1}{}}

\newcommand{\ratkaisu}[1]{\ifthenelse{\tversio = 2 \OR \tversio = 3}{\noindent{\bf Suggestion for a solution:}  #1}{}}

\newcommand{\ratkaisuT}[1]{\ifthenelse{\tversio = 2 \OR \tversio = 4}{\noindent{\bf Suggestion for a solution:}  #1}{}}

\newcommand{\ratkaisuH}[1]{\ifthenelse{\tversio > 1}{\noindent{\bf Suggestion for a solution:}  #1}{}}


