\newcounter{tehtavasarjaCounter}
\newcommand{\tehtavasarja}[1][]{
    \ifthenelse{\isempty{#1}}
    {
        \stepcounter{tehtavasarjaCounter}
        \ifthenelse{\tversio < 4}
        {\subsubsection*{Tehtäväsarja \Roman{tehtavasarjaCounter}}}
        {}
    }{
        \ifthenelse{\tversio < 4}
        {\subsubsection*{#1}}
        {}
    }
}

\newcounter{tehtavaCounter}
\NewEnviron{tehtava}{
    \ifthenelse{\tversio < 4}{
        \begin{enumerate}
            \setcounter{enumi}{\value{tehtavaCounter}}
            \item \BODY
            \setcounter{tehtavaCounter}{\value{enumi}}
        \end{enumerate}
    }{
        \stepcounter{tehtavaCounter}
    }
}

\NewEnviron{tehtavaT}{
    \begin{enumerate}
        \setcounter{enumi}{\value{tehtavaCounter}}
        \item\hspace{-6pt}${}^\star$ \BODY
        \setcounter{tehtavaCounter}{\value{enumi}}
    \end{enumerate}
}
\newcommand{\tehtavasarjaT}{
    \ifthenelse{\tversio > 3}{
        \noindent{\textbf{Tehtävä:}}
    }{}
}
\NewEnviron{tehtavaH}{
    \begin{enumerate}
        \setcounter{enumi}{\value{tehtavaCounter}}
        \item \BODY
        \setcounter{tehtavaCounter}{\value{enumi}}
    \end{enumerate}
}

